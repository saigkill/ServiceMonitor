# Basic editorconfig file

root = true

[*]
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{cs,vb}]
dotnet_diagnostic.CA1822.severity = none

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,csproj}]
indent_style = space
indent_size = 2

[*.{py,rs}]
indent_style = space
